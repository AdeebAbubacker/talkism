rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAllowedUserRole(role) {
      return role in ['user', 'caller', 'receiver'];
    }

    function isValidOwnUserWrite(userId) {
      return isSelf(userId)
        && request.resource.data.uid == request.auth.uid
        && isAllowedUserRole(request.resource.data.role);
    }

    function isParticipant() {
      return signedIn()
        && (
          resource.data.callerId == request.auth.uid
          || resource.data.receiverId == request.auth.uid
        );
    }

    function isCreatingOwnCall() {
      return signedIn()
        && request.resource.data.callerId == request.auth.uid
        && request.resource.data.receiverId is string
        && request.resource.data.receiverId != request.auth.uid
        && request.resource.data.callType in ['audio', 'video'];
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if isValidOwnUserWrite(userId);
    }

    match /calls/{callId} {
      allow create: if isCreatingOwnCall();
      allow read: if isParticipant();
      allow update: if isParticipant();
    }
  }
}
